# Frontend
VITE_API_BASE_URL=

# Backend
APP_ENV=development
HTTP_ADDR=:8080
KAIROS_DB_PATH=./tmp/kairos.db

# Auth
AUTH_ENABLED=true
ALLOW_SIGNUP=true
SESSION_COOKIE_NAME=kairos_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=720

# Optional admin bootstrap
BOOTSTRAP_ADMIN=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
