# Backend
APP_ENV=development
HTTP_ADDR=:8080
KAIROS_DB_PATH=./tmp/kairos.db

# Auth
AUTH_ENABLED=true
ALLOW_SIGNUP=true
SESSION_COOKIE_NAME=kairos_session
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=720
PROVIDER_SECRET_KEY=

# Optional admin bootstrap
BOOTSTRAP_ADMIN=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=

# Providers
ENABLE_USER_PROVIDERS=true
ALLOW_USER_CUSTOM_BASE_URL=true
ALLOW_USER_DISABLE_SYSTEM_PROVIDER=true
ALLOW_USER_MODEL_SYNC=true
DEFAULT_CHAT_MODEL=
LOCK_CHAT_MODEL=false

# Optional server default provider
SYSTEM_PROVIDER_1_ID=system-default
SYSTEM_PROVIDER_1_KIND=openai_compatible
SYSTEM_PROVIDER_1_LABEL=Server Default
SYSTEM_PROVIDER_1_BASE_URL=
SYSTEM_PROVIDER_1_API_KEY=
SYSTEM_PROVIDER_1_ENABLED=false
SYSTEM_PROVIDER_1_ALLOW_DISABLE=true
SYSTEM_PROVIDER_1_MODEL_SYNC=true
SYSTEM_PROVIDER_1_MODELS=
